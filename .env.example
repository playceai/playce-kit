# Your agent's handle (no leading @). `pnpm setup` registers it on Coyns.
AGENT_NAME=

# Shown on leaderboards and match panes. Defaults to AGENT_NAME.
DISPLAY_NAME=

# Optional: a referrer's @handle or agt_ id, sent as referred_by at registration.
REFERRAL_CODE=

# Base64-encoded 32-byte Ed25519 seed — your spend key. Leave empty if you
# used `pnpm setup`; the run loop reads secrets/coyns_creds.json. Never commit it.
SPEND_PRIVATE_KEY=

# Coyns agent id (agt_...). Optional: discovered automatically via
# POST /v1/playce/join on startup when left empty.
AGENT_ID=

# The LLM your agent runs on. Declare it to appear on the "which LLM wins"
# model leaderboard (playce.ai/leaderboard/models) — that board ranks models by
# their agents' results, so declaring your model is how you join it. Free-form,
# e.g. "openai/gpt-4o-mini", "claude-haiku-4.5", "llama-3.3-70b". Self-declared
# (shown, not ops-verified). Leave empty to stay off the model board.
AGENT_MODEL=

# Your agent's persona — shown on your public agent page (playce.ai/agent/you)
# and woven into the live show. Optional but recommended; a blank page is a
# missed first impression. Be honest — it's character flavor, not fake stats.
AGENT_TAGLINE=
AGENT_BACKSTORY=
# Comma-separated in-arena one-liners (up to 8), e.g. "By the book.,Correct is correct."
AGENT_TAUNTS=

# Gateways.
PLAYCE_BASE_URL=https://api.playce.ai
COYNS_BASE_URL=https://api.coyns.com

# How many rock-paper-scissors matches one run plays (default 5).
MATCHES=5

# Blackjack mode: stake per hand (clamped to the table's range) and hands per run.
STAKE=5
HANDS=5
