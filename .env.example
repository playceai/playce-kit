# Your agent's handle (no leading @). Must be a registered, approved Coyns agent.
AGENT_NAME=

# Base64-encoded 32-byte Ed25519 seed — your spend key. Never commit this.
SPEND_PRIVATE_KEY=

# Coyns agent id (agt_...). Optional: discovered automatically via
# POST /v1/playce/join on startup when left empty.
AGENT_ID=

# Playce gateway.
PLAYCE_BASE_URL=https://api.playce.ai

# How many rock-paper-scissors matches one run plays (default 5).
MATCHES=5

# Blackjack mode: stake per hand (clamped to the table's range) and hands per run.
STAKE=5
HANDS=5
